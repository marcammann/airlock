{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://airlock.dev/schemas/secret-provider-config.schema.json",
  "title": "SecretProviderConfig",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "const": "airlock.dev/v1alpha1"
    },
    "kind": {
      "const": "SecretProviderConfig"
    },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "namespace": {
          "type": "string"
        }
      }
    },
    "spec": {
      "type": "object",
      "required": ["provider", "vault"],
      "additionalProperties": false,
      "properties": {
        "provider": {
          "const": "vault"
        },
        "vault": {
          "type": "object",
          "required": ["address", "auth"],
          "additionalProperties": false,
          "properties": {
            "address": {
              "type": "string",
              "minLength": 1
            },
            "auth": {
              "type": "object",
              "required": ["method", "mount", "audience"],
              "additionalProperties": false,
              "properties": {
                "method": {
                  "const": "spiffe-jwt"
                },
                "mount": {
                  "type": "string",
                  "minLength": 1
                },
                "audience": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "defaults": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "engine": {
                  "const": "kv-v2"
                },
                "mount": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
